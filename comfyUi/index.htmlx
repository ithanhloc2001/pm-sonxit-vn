<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ComfyUI API Tester</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap"
    rel="stylesheet" />
  <style>
    :root {
      --bg: #0a0a0f;
      --surface: #111118;
      --surface2: #1a1a24;
      --border: #2a2a38;
      --accent: #7c6dfa;
      --accent2: #fa6d9a;
      --green: #4ade80;
      --yellow: #facc15;
      --red: #f87171;
      --text: #e8e6ff;
      --muted: #6b6880;
      --mono: 'Space Mono', monospace;
      --sans: 'DM Sans', sans-serif;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      min-height: 100vh;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: linear-gradient(rgba(124, 109, 250, 0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(124, 109, 250, 0.04) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    .wrap {
      position: relative;
      z-index: 1;
      max-width: 960px;
      margin: 0 auto;
      padding: 48px 24px;
    }

    header {
      display: flex;
      align-items: baseline;
      gap: 16px;
      margin-bottom: 48px;
      border-bottom: 1px solid var(--border);
      padding-bottom: 24px;
    }

    header h1 {
      font-family: var(--mono);
      font-size: 22px;
      font-weight: 700;
      color: var(--text);
    }

    header h1 span {
      color: var(--accent);
    }

    .badge {
      font-family: var(--mono);
      font-size: 11px;
      padding: 3px 8px;
      border-radius: 4px;
      background: rgba(124, 109, 250, 0.15);
      color: var(--accent);
      border: 1px solid rgba(124, 109, 250, 0.3);
      letter-spacing: 1px;
    }

    .api-url {
      margin-left: auto;
      font-family: var(--mono);
      font-size: 12px;
      color: var(--muted);
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 6px 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--green);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {

      0%,
      100% {
        opacity: 1
      }

      50% {
        opacity: 0.4
      }
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    @media(max-width:700px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
    }

    .card-title {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 2px;
      color: var(--muted);
      text-transform: uppercase;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .card-title::before {
      content: '';
      width: 3px;
      height: 14px;
      background: var(--accent);
      border-radius: 2px;
    }

    .upload-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 16px;
    }

    /* Upload zone hoàn toàn mới - không dùng input overlay */
    .upload-zone {
      border: 1.5px dashed var(--border);
      border-radius: 10px;
      padding: 16px 12px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      background: var(--surface2);
      min-height: 110px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 6px;
      user-select: none;
    }

    .upload-zone:hover {
      border-color: var(--accent);
      background: rgba(124, 109, 250, 0.06);
    }

    .upload-zone.has-file {
      border-style: solid;
      border-color: rgba(74, 222, 128, 0.4);
    }

    .upload-zone .icon {
      font-size: 24px;
    }

    .upload-zone .label {
      font-size: 12px;
      color: var(--muted);
    }

    .upload-zone .sublabel {
      font-size: 11px;
      color: rgba(107, 104, 128, 0.7);
    }

    .upload-zone img {
      max-width: 100%;
      max-height: 70px;
      border-radius: 6px;
      object-fit: cover;
      display: none;
    }

    .upload-zone.has-file img {
      display: block;
    }

    .upload-zone.has-file .placeholder-content {
      display: none;
    }

    .fname {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--green);
      word-break: break-all;
      display: none;
    }

    .upload-zone.has-file .fname {
      display: block;
    }

    .field {
      margin-bottom: 14px;
    }

    .field label {
      display: block;
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 6px;
      font-family: var(--mono);
    }

    .field textarea,
    .field input[type=text],
    .field input[type=number] {
      width: 100%;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-family: var(--sans);
      font-size: 14px;
      padding: 10px 14px;
      outline: none;
      resize: vertical;
      transition: border-color 0.2s;
    }

    .field textarea:focus,
    .field input:focus {
      border-color: var(--accent);
    }

    .field textarea {
      min-height: 72px;
      line-height: 1.5;
    }

    .row2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    /* Hidden file inputs */
    #file1,
    #file2 {
      display: none;
    }

    .btn {
      width: 100%;
      padding: 13px;
      border-radius: 8px;
      border: none;
      font-family: var(--mono);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 1px;
      cursor: pointer;
      transition: all 0.15s;
    }

    .btn-primary {
      background: var(--accent);
      color: #fff;
    }

    .btn-primary:hover {
      background: #9585fb;
      transform: translateY(-1px);
    }

    .btn-primary:active {
      transform: translateY(0);
    }

    .btn-primary:disabled {
      background: var(--surface2);
      color: var(--muted);
      cursor: not-allowed;
      transform: none;
    }

    .status-panel {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
      margin-top: 20px;
      display: none;
    }

    .status-panel.show {
      display: block;
    }

    .status-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }

    .status-badge {
      font-family: var(--mono);
      font-size: 11px;
      padding: 4px 10px;
      border-radius: 20px;
      letter-spacing: 0.5px;
      font-weight: 700;
    }

    .s-pending {
      background: rgba(250, 204, 21, 0.15);
      color: var(--yellow);
      border: 1px solid rgba(250, 204, 21, 0.3);
    }

    .s-processing {
      background: rgba(124, 109, 250, 0.15);
      color: var(--accent);
      border: 1px solid rgba(124, 109, 250, 0.3);
    }

    .s-completed {
      background: rgba(74, 222, 128, 0.15);
      color: var(--green);
      border: 1px solid rgba(74, 222, 128, 0.3);
    }

    .s-failed {
      background: rgba(248, 113, 113, 0.15);
      color: var(--red);
      border: 1px solid rgba(248, 113, 113, 0.3);
    }

    .job-id {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      background: var(--surface2);
      padding: 4px 10px;
      border-radius: 6px;
      border: 1px solid var(--border);
    }

    .progress-wrap {
      margin-bottom: 16px;
    }

    .progress-label {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 6px;
      display: flex;
      justify-content: space-between;
    }

    .progress-track {
      height: 6px;
      background: var(--surface2);
      border-radius: 3px;
      overflow: hidden;
      border: 1px solid var(--border);
    }

    .progress-bar {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      border-radius: 3px;
      transition: width 0.4s ease;
      width: 0%;
    }

    .json-block {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 16px;
      font-family: var(--mono);
      font-size: 12px;
      line-height: 1.7;
      white-space: pre-wrap;
      word-break: break-all;
      max-height: 220px;
      overflow-y: auto;
      color: #a8a4d4;
      margin-bottom: 16px;
    }

    .json-block .key {
      color: var(--accent2);
    }

    .json-block .str {
      color: #a8e6a3;
    }

    .json-block .num {
      color: #fbbf24;
    }

    .json-block .bool {
      color: #60a5fa;
    }

    .result-img-wrap {
      border: 1px solid rgba(74, 222, 128, 0.3);
      border-radius: 10px;
      overflow: hidden;
      display: none;
      background: var(--surface2);
    }

    .result-img-wrap.show {
      display: block;
    }

    .result-img-wrap img {
      width: 100%;
      display: block;
    }

    .result-img-wrap .img-footer {
      padding: 10px 14px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .download-btn {
      font-family: var(--mono);
      font-size: 11px;
      padding: 6px 14px;
      background: rgba(74, 222, 128, 0.15);
      color: var(--green);
      border: 1px solid rgba(74, 222, 128, 0.3);
      border-radius: 6px;
      cursor: pointer;
      text-decoration: none;
    }

    .download-btn:hover {
      background: rgba(74, 222, 128, 0.25);
    }

    .log-wrap {
      margin-top: 20px;
    }

    .log-title {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 2px;
      color: var(--muted);
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .log-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 4px;
      max-height: 160px;
      overflow-y: auto;
    }

    .log-list li {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      padding: 4px 10px;
      border-left: 2px solid var(--border);
      display: flex;
      gap: 12px;
    }

    .log-list li .t {
      color: rgba(107, 104, 128, 0.6);
      min-width: 70px;
    }

    .log-list li.ok {
      border-color: var(--green);
      color: #a7f3d0;
    }

    .log-list li.err {
      border-color: var(--red);
      color: #fca5a5;
    }

    .log-list li.inf {
      border-color: var(--accent);
      color: #c4bbff;
    }

    ::-webkit-scrollbar {
      width: 4px;
    }

    ::-webkit-scrollbar-track {
      background: transparent;
    }

    ::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 2px;
    }

    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }

    .spinner {
      display: inline-block;
      width: 14px;
      height: 14px;
      border: 2px solid rgba(255, 255, 255, 0.2);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      vertical-align: middle;
      margin-right: 8px;
    }
  </style>
</head>

<body>
  <div class="wrap">
    <header>
      <h1><span>//</span> ComfyUI API Tester</h1>
      <span class="badge">v1.0</span>
      <div class="api-url"><span class="dot"></span><span id="base-url-display">https://api.sonxit.vn</span>
      </div>
    </header>

    <!-- Hidden file inputs — hoàn toàn tách khỏi UI -->
    <input type="file" id="file1" accept="image/*" />
    <input type="file" id="file2" accept="image/*" />

    <div class="grid">
      <div class="card">
        <div class="card-title">Input</div>
        <div class="upload-row">
          <div class="upload-zone" id="zone1" onclick="document.getElementById('file1').click()">
            <div class="placeholder-content">
              <div class="icon">🧍</div>
              <div class="label">Image 1</div>
              <div class="sublabel">Ảnh gốc (model)</div>
            </div>
            <img id="preview1" src="" alt="" />
            <div class="fname" id="fname1"></div>
          </div>
          <div class="upload-zone" id="zone2" onclick="document.getElementById('file2').click()">
            <div class="placeholder-content">
              <div class="icon">🕺</div>
              <div class="label">Image 2</div>
              <div class="sublabel">Ảnh tư thế (pose)</div>
            </div>
            <img id="preview2" src="" alt="" />
            <div class="fname" id="fname2"></div>
          </div>
        </div>

        <div class="field">
          <label>PROMPT</label>
          <textarea
            id="prompt">Transform the model in image1 into the pose shown in image2 while maintaining character consistency, lighting, shadow and sharpness, clothes detail</textarea>
        </div>
        <div class="row2">
          <div class="field"><label>STEPS</label><input type="number" id="steps" value="10" min="1" max="50" /></div>
          <div class="field"><label>SEED (-1 = random)</label><input type="number" id="seed" value="-1" /></div>
        </div>
        <div class="field">
          <label>API BASE URL</label>
          <input type="text" id="base-url" value="https://api.sonxit.vn"
            oninput="document.getElementById('base-url-display').textContent=this.value" />
        </div>
        <button class="btn btn-primary" id="run-btn" onclick="runJob()">▶ &nbsp;RUN WORKFLOW</button>
      </div>

      <div class="card">
        <div class="card-title">Response</div>
        <div id="json-out" class="json-block" style="min-height:80px;color:var(--muted);">// Chưa có response...</div>
        <div class="progress-wrap" id="prog-wrap" style="display:none">
          <div class="progress-label"><span>Đang xử lý...</span><span id="prog-pct">0%</span></div>
          <div class="progress-track">
            <div class="progress-bar" id="prog-bar"></div>
          </div>
        </div>
        <div class="result-img-wrap" id="result-wrap">
          <img id="result-img" src="" alt="Result" />
          <div class="img-footer">
            <span style="font-family:var(--mono);font-size:11px;color:var(--green)">✓ COMPLETED</span>
            <a id="download-link" class="download-btn" download="result.png">↓ DOWNLOAD</a>
          </div>
        </div>
      </div>
    </div>

    <div class="status-panel" id="status-panel">
      <div class="status-row">
        <span class="status-badge s-pending" id="status-badge">PENDING</span>
        <span class="job-id" id="job-id-display">—</span>
      </div>
    </div>

    <div class="log-wrap">
      <div class="log-title">// Request log</div>
      <ul class="log-list" id="log-list">
        <li><span class="t">—</span><span>Chờ request...</span></li>
      </ul>
    </div>
  </div>

  <script>
    const API = () => document.getElementById('base-url').value.replace(/\/$/, '');

    // Lắng nghe change trực tiếp trên input hidden — không qua onclick
    document.getElementById('file1').addEventListener('change', function () {
      handleFile(1, this.files[0]);
    });
    document.getElementById('file2').addEventListener('change', function () {
      handleFile(2, this.files[0]);
    });

    function handleFile(n, file) {
      if (!file) return;
      const reader = new FileReader();
      reader.onload = e => {
        document.getElementById('preview' + n).src = e.target.result;
        document.getElementById('fname' + n).textContent = file.name;
        document.getElementById('zone' + n).classList.add('has-file');
      };
      reader.readAsDataURL(file);
      addLog('✓ Đã chọn image' + n + ': ' + file.name, 'ok');
    }

    function addLog(msg, type = '') {
      const ul = document.getElementById('log-list');
      if (ul.children.length === 1 && ul.children[0].querySelector('.t')?.textContent === '—') ul.innerHTML = '';
      const li = document.createElement('li');
      if (type) li.classList.add(type);
      li.innerHTML = `<span class="t">${new Date().toTimeString().slice(0, 8)}</span><span>${msg}</span>`;
      ul.prepend(li);
    }

    function renderJSON(obj) {
      return JSON.stringify(obj, null, 2)
        .replace(/"([^"]+)":/g, '<span class="key">"$1"</span>:')
        .replace(/: "([^"]+)"/g, ': <span class="str">"$1"</span>')
        .replace(/: (\d+\.?\d*)/g, ': <span class="num">$1</span>')
        .replace(/: (true|false)/g, ': <span class="bool">$1</span>');
    }

    function setStatus(s) {
      const badge = document.getElementById('status-badge');
      badge.className = 'status-badge s-' + s;
      badge.textContent = s.toUpperCase();
    }

    let pollTimer = null;

    async function runJob() {
      const f1 = document.getElementById('file1').files[0];
      const f2 = document.getElementById('file2').files[0];

      if (!f1 || !f2) {
        addLog('⚠ Vui lòng chọn đủ 2 ảnh', 'err');
        return;
      }

      const btn = document.getElementById('run-btn');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner"></span>SENDING...';
      document.getElementById('result-wrap').classList.remove('show');
      document.getElementById('prog-wrap').style.display = 'none';
      document.getElementById('status-panel').classList.add('show');
      setStatus('pending');

      const fd = new FormData();
      fd.append('image1', f1, f1.name);
      fd.append('image2', f2, f2.name);
      fd.append('prompt', document.getElementById('prompt').value);
      fd.append('steps', document.getElementById('steps').value);
      fd.append('seed', document.getElementById('seed').value);

      addLog('POST ' + API() + '/rechange-image', 'inf');

      try {
        const res = await fetch(API() + '/rechange-image', { method: 'POST', body: fd });
        const data = await res.json();
        document.getElementById('json-out').innerHTML = renderJSON(data);
        document.getElementById('job-id-display').textContent = data.job_id || '—';
        addLog('202 Accepted — job_id: ' + data.job_id, 'ok');
        setStatus('processing');
        document.getElementById('prog-wrap').style.display = 'block';
        btn.innerHTML = '<span class="spinner"></span>PROCESSING...';
        pollStatus(data.job_id);
      } catch (e) {
        document.getElementById('json-out').textContent = 'Error: ' + e.message;
        addLog('❌ ' + e.message, 'err');
        btn.disabled = false;
        btn.innerHTML = '▶ &nbsp;RUN WORKFLOW';
      }
    }

    async function pollStatus(jobId) {
      if (pollTimer) clearInterval(pollTimer);
      pollTimer = setInterval(async () => {
        try {
          const res = await fetch(API() + '/status/' + jobId);
          const data = await res.json();
          document.getElementById('json-out').innerHTML = renderJSON(data);
          const pct = data.progress || 0;
          document.getElementById('prog-bar').style.width = pct + '%';
          document.getElementById('prog-pct').textContent = pct + '%';
          setStatus(data.status);
          if (data.status === 'completed') {
            clearInterval(pollTimer);
            addLog('✓ completed', 'ok');
            document.getElementById('prog-bar').style.width = '100%';
            document.getElementById('prog-pct').textContent = '100%';
            await loadResult(jobId);
          } else if (data.status === 'failed') {
            clearInterval(pollTimer);
            addLog('❌ failed — ' + data.error, 'err');
            document.getElementById('run-btn').disabled = false;
            document.getElementById('run-btn').innerHTML = '▶ &nbsp;RUN WORKFLOW';
          } else {
            addLog('polling — ' + data.status + ' ' + pct + '%');
          }
        } catch (e) { addLog('Poll error: ' + e.message, 'err'); }
      }, 2000);
    }

    async function loadResult(jobId) {
      try {
        const res = await fetch(API() + '/result/' + jobId);
        const blob = await res.blob();
        const url = URL.createObjectURL(blob);
        document.getElementById('result-img').src = url;
        document.getElementById('download-link').href = url;
        document.getElementById('result-wrap').classList.add('show');
        document.getElementById('prog-wrap').style.display = 'none';
        addLog('✓ Ảnh kết quả đã tải về', 'ok');
      } catch (e) { addLog('Lỗi tải ảnh: ' + e.message, 'err'); }
      const btn = document.getElementById('run-btn');
      btn.disabled = false;
      btn.innerHTML = '▶ &nbsp;RUN WORKFLOW';
    }
  </script>
</body>

</html>